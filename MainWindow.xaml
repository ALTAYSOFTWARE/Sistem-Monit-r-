                    </StackPanel>

                </ScrollViewer>

                <ScrollViewer x:Name="viewAlarms" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="18,16,18,18">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="🎨 Tema Rengi Seçimi" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="40" Height="40" Background="#00D4FF" Margin="0,0,12,0" Tag="#00D4FF" Click="BtnTheme_Click" Style="{StaticResource ThemeBtn}"/>
                                    <Button Width="40" Height="40" Background="#00FF88" Margin="0,0,12,0" Tag="#00FF88" Click="BtnTheme_Click" Style="{StaticResource ThemeBtn}"/>
                                    <Button Width="40" Height="40" Background="#FFD93D" Margin="0,0,12,0" Tag="#FFD93D" Click="BtnTheme_Click" Style="{StaticResource ThemeBtn}"/>
                                    <Button Width="40" Height="40" Background="#FF44AA" Margin="0,0,12,0" Tag="#FF44AA" Click="BtnTheme_Click" Style="{StaticResource ThemeBtn}"/>
                                    <Button Width="40" Height="40" Background="#FF5555" Margin="0,0,12,0" Tag="#FF5555" Click="BtnTheme_Click" Style="{StaticResource ThemeBtn}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="⚙️ Genel Sistem Ayarları" Style="{StaticResource SectionHeader}"/>
                                <Border Background="#0F0F28" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <CheckBox x:Name="chkStartup" Content="🚀  Windows açıldığında otomatik başlat (Arka planda çalışır)" Margin="0,0,0,12"/>
                                        <CheckBox x:Name="chkTray" Content="⬇️  Pencereyi kapatınca sistem tepsisine (sağ alt köşe) küçült" Margin="0,0,0,8"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="🔔 Alarm Ayarları" Style="{StaticResource SectionHeader}"/>
                                <Border Background="#0F0F28" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <CheckBox x:Name="chkAlarmSound" Content="🔊  Alarm durumunda sesli uyarı çal" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="⏱️ Alarm Susma Süresi (Saniye): " Foreground="#C0C0E0" VerticalAlignment="Center"/>
                                            <TextBox x:Name="txtSnoozeSec" Style="{StaticResource DarkInput}" Text="15" Width="50" Height="28"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Background="#0F0F28" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <CheckBox x:Name="chkCpuAlarm" Content="🔲  CPU Kullanımı Alarmı" IsChecked="True" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Eşik: " Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="txtCpuThreshold" Style="{StaticResource DarkInput}" Text="90" Width="60" Height="28" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Slider Grid.Column="1" x:Name="sldrCpu" Minimum="50" Maximum="100" Value="90" Width="140" VerticalAlignment="Center" ValueChanged="SldrCpu_Changed"/>
                                    </Grid>
                                </Border>
                                <Border Background="#0F0F28" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <CheckBox x:Name="chkRamAlarm" Content="💾  RAM Kullanımı Alarmı" IsChecked="True" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Eşik: " Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                                <TextBox x:Name="txtRamThreshold" Style="{StaticResource DarkInput}" Text="85" Width="60" Height="28" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Slider Grid.Column="1" x:Name="sldrRam" Minimum="50" Maximum="100" Value="85" Width="140" VerticalAlignment="Center" ValueChanged="SldrRam_Changed"/>
                                    </Grid>
                                </Border>
                                <Border Background="#0F0F28" CornerRadius="10" Padding="16,14" Margin="0,0,0,20">
                                    <StackPanel>
                                        <CheckBox x:Name="chkDiskAlarm" Content="💿  Disk Doluluk Alarmı" IsChecked="True" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Eşik: " Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                            <TextBox x:Name="txtDiskThreshold" Style="{StaticResource DarkInput}" Text="90" Width="60" Height="28" Margin="6,0,0,0"/>
                                            <TextBlock Text="%" Foreground="#7777AA" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Button Content="💾  Ayarları Kaydet" Style="{StaticResource ActionBtn}" HorizontalAlignment="Left" Padding="20,9" Click="BtnSaveAlarms_Click" Background="#0A3040"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="📋 Alarm Geçmişi" Style="{StaticResource SectionHeader}" Margin="0"/>
                                    <Button Content="Temizle" Style="{StaticResource ActionBtn}" HorizontalAlignment="Right" Padding="10,4" Click="BtnClearAlarmHistory_Click"/>
                                </Grid>
                                <ListView x:Name="lvAlarmHistory" Height="250" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Zaman" Width="140" DisplayMemberBinding="{Binding Time}"/>
                                            <GridViewColumn Header="Tür" Width="100" DisplayMemberBinding="{Binding Type}"/>
                                            <GridViewColumn Header="Mesaj" Width="350" DisplayMemberBinding="{Binding Message}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>