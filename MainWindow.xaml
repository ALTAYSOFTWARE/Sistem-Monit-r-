<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚡ Sistem Monitörü"
        Height="820" Width="1200" MinHeight="650" MinWidth="950"
        WindowStartupLocation="CenterScreen" Background="#0D0D1A">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#00D4FF"/>
        <SolidColorBrush x:Key="CpuColor"    Color="#00D4FF"/>
        <SolidColorBrush x:Key="RamColor"    Color="#FF6B6B"/>
        <SolidColorBrush x:Key="DiskColor"   Color="#FFD93D"/>
        <SolidColorBrush x:Key="NetColor"    Color="#6BCB77"/>
        <SolidColorBrush x:Key="BgSidebar"   Color="#12122A"/>
        <SolidColorBrush x:Key="BgCard"      Color="#181830"/>
        <SolidColorBrush x:Key="BgHeader"    Color="#12122A"/>
        <SolidColorBrush x:Key="TextPri"     Color="#E8E8F5"/>
        <SolidColorBrush x:Key="TextSec"     Color="#7777AA"/>
        <SolidColorBrush x:Key="Separator"   Color="#1E1E40"/>

        <Style x:Key="ThemeBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="20" Background="{TemplateBinding Background}" BorderBrush="#E8E8F5" BorderThickness="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7777AA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,0,0"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Margin="8,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C1C3E"/>
                                <Setter Property="Foreground" Value="#C0C0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#242452"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#1A1A40"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#181830"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8F5"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7777AA"/>
            <Setter Property="FontSize" Value="11.5"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A52"/>
            <Setter Property="Foreground" Value="#C0C0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#363670"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="thumbBorder" CornerRadius="4" Background="#3A3A5C" Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbBorder" Property="Background" Value="#55557A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumbBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C0C0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="chkBorder" Width="18" Height="18" CornerRadius="4" Background="#0F0F28" BorderBrush="#2A2A52" BorderThickness="1.5" VerticalAlignment="Center">
                                <Path x:Name="checkMark" Visibility="Hidden" Data="M 3,9 L 7,13 L 14,4" Stroke="{DynamicResource AccentColor}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="chkBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" Background="#1A1A38" CornerRadius="3" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="{DynamicResource AccentColor}" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="sliderThumb" Width="16" Height="16" Fill="{DynamicResource AccentColor}" Stroke="#12122A" StrokeThickness="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A3A"/>
            <Setter Property="Foreground" Value="#D0D0F0"/>
            <Setter Property="BorderBrush" Value="#2A2A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentColor}"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#C8C8E8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#1A1A38"/>
            <Setter Property="Foreground" Value="#8888BB"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C8C8E8"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="0,1">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E1E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#252550"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="78"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="⚡ SysMonitor Pro" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Advanced Yönetim Paneli" FontSize="10.5" Foreground="#55557A" Margin="1,2,0,0"/>
                </StackPanel>
                <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Background="{StaticResource Separator}" Margin="10,0"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="navPanel" Margin="0,10,0,10">
                        <Button x:Name="btnNavDashboard" Style="{StaticResource NavBtnActive}" Tag="dashboard" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavCpu" Style="{StaticResource NavBtn}" Tag="cpu" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔲" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="İşlemci (CPU)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavRam" Style="{StaticResource NavBtn}" Tag="ram" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Bellek (RAM)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavDisk" Style="{StaticResource NavBtn}" Tag="disk" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💿" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Disk" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavNetwork" Style="{StaticResource NavBtn}" Tag="network" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ağ İzleyici" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="#1E1E40" Margin="15,8,15,8"/>

                        <Button x:Name="btnNavFirewall" Style="{StaticResource NavBtn}" Tag="firewall" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛡️" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Güvenlik Duvarı" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavProcesses" Style="{StaticResource NavBtn}" Tag="processes" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Süreçler" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavServices" Style="{StaticResource NavBtn}" Tag="services" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Servisler" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavStartup" Style="{StaticResource NavBtn}" Tag="startup" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚀" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Başlangıç" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavTasks" Style="{StaticResource NavBtn}" Tag="tasks" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏰" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Zamanlı Görevler" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavPrograms" Style="{StaticResource NavBtn}" Tag="programs" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Uygulamalar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="#1E1E40" Margin="15,8,15,8"/>

                        <Button x:Name="btnNavHistory" Style="{StaticResource NavBtn}" Tag="history" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📈" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Oturum Geçmişi" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnNavTools" Style="{StaticResource NavBtn}" Tag="tools" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛠️" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Araçlar / Rapor" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavCrashLogs" Style="{StaticResource NavBtn}" Tag="crashlogs" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Hata Kayıtları" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnNavAlarms" Style="{StaticResource NavBtn}" Tag="alarms" Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔔" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ayarlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="16,0,0,14">
                    <Border Height="1" Background="{StaticResource Separator}" Margin="0,0,10,10"/>
                    <TextBlock x:Name="txtUptime" Text="⏱ Hesaplanıyor..." FontSize="11" Foreground="#55557A"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgHeader}" BorderBrush="#1A1A3A" BorderThickness="0,0,0,1">
                <Grid Margin="22,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtPageTitle" Text="📊 Dashboard" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPri}" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button Content="🧹 RAM Temizle" Style="{StaticResource ActionBtn}" Margin="0,0,10,0" Background="#993333" Foreground="#FFEEEE" FontWeight="Bold" Click="BtnCleanMemory_Click"/>
                        <Button Content="👻 Mini Ekran" Style="{StaticResource ActionBtn}" Margin="0,0,16,0" Click="BtnMiniWidget_Click"/>
                        <TextBlock x:Name="txtPcName" FontSize="12" Foreground="#55557A" Margin="0,0,18,0"/>
                        <TextBlock x:Name="txtDateTime" FontSize="12" Foreground="#55557A" FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="borderAlarmBanner" Grid.Row="1" Background="#2A1020" BorderBrush="#FF4060" BorderThickness="0,0,0,2" Visibility="Collapsed" Padding="18,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🚨" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtAlarmMsg" Foreground="#FF8899" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Style="{StaticResource ActionBtn}" Content="✕ Kapat" Click="BtnDismissAlarm_Click" Background="#3A1825"/>
                </Grid>
            </Border>

            <Grid x:Name="contentGrid" Grid.Row="2">
                <ScrollViewer x:Name="viewDashboard" Visibility="Visible" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="18,16,18,18">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="50"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="🔲" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentColor}" FontSize="18" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="İŞLEMCİ" Style="{StaticResource LabelText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtCpuPct" Grid.Row="1" Text="0%" FontSize="38" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" Margin="0,0,0,4"/>
                                    <Canvas x:Name="canvasCpuBar" Grid.Row="2" Height="4" Margin="0,0,0,8"/>
                                    <Canvas x:Name="chartCpuCard" Grid.Row="3"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,7,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="50"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="💾" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource RamColor}" FontSize="18" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="BELLEK" Style="{StaticResource LabelText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtRamPct" Grid.Row="1" Text="0%" FontSize="38" FontWeight="Bold" Foreground="{StaticResource RamColor}" Margin="0,0,0,4"/>
                                    <Canvas x:Name="canvasRamBarCard" Grid.Row="2" Height="4" Margin="0,0,0,8"/>
                                    <Canvas x:Name="chartRamCard" Grid.Row="3"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="7,0,7,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="56"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="💿" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource DiskColor}" FontSize="18" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="DİSK I/O" Style="{StaticResource LabelText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtDiskIO" Grid.Row="1" Text="0.0 MB/s" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DiskColor}" Margin="0,0,0,8"/>
                                    <Canvas x:Name="chartDiskCard" Grid.Row="2"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource Card}" Margin="7,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="56"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="🌐" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource NetColor}" FontSize="18" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="AĞ" Style="{StaticResource LabelText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtNetIO" Grid.Row="1" Text="0 KB/s" FontSize="28" FontWeight="Bold" Foreground="{StaticResource NetColor}" Margin="0,0,0,8"/>
                                    <Canvas x:Name="chartNetCard" Grid.Row="2"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="190"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="CPU Kullanımı — Son 60 Saniye" Style="{StaticResource SectionHeader}" Margin="0"/>
                                        <TextBlock x:Name="txtCpuSubInfo" HorizontalAlignment="Right" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Canvas x:Name="chartCpuBig" Grid.Row="1"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
