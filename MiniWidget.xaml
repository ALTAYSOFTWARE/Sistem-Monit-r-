<Window x:Class="MiniWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniWidget" Height="140" Width="220"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#CC12122A" CornerRadius="12" BorderBrush="#00D4FF" BorderThickness="1.5" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="⚡ SysMon" Foreground="#00D4FF" FontWeight="Bold" FontSize="13" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="✕" Width="20" Height="20" Background="Transparent" Foreground="#8888AA" BorderThickness="0" HorizontalAlignment="Right" Click="BtnClose_Click" Cursor="Hand"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="CPU:" Foreground="#7777AA" Width="40" FontSize="13"/>
                    <TextBlock x:Name="txtMiniCpu" Text="0%" Foreground="#00D4FF" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="RAM:" Foreground="#7777AA" Width="40" FontSize="13"/>
                    <TextBlock x:Name="txtMiniRam" Text="0%" Foreground="#FF6B6B" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Ping:" Foreground="#7777AA" Width="40" FontSize="13"/>
                    <TextBlock x:Name="txtMiniPing" Text="--" Foreground="#6BCB77" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>